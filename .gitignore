frontend/yarn-error.log*

# ===== BACKEND (Go) =====
api/bin/
api/dist/
api/tmp/
api/*.exe
api/*.exe~
api/*.dll
api/*.so
api/*.dylib
api/*.test
api/*.out
api/go.work
api/.env
api/build-errors.log

